<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STAAR Readiness — Math & Science for Families</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════════════
   DESIGN: Warm editorial — like a magazine made for parents.
   Cream backgrounds, deep navy, amber accents. Fraunces serif
   display pairs with Jakarta Sans body. Feels trustworthy &
   approachable, not institutional.
═══════════════════════════════════════════════════════════════ */
:root {
  --navy:   #1a2e4a;
  --navy2:  #243d5e;
  --blue:   #2563a8;
  --cream:  #faf7f2;
  --cream2: #f2ede4;
  --amber:  #d4820a;
  --amber2: #fdf0d8;
  --amber3: #fff8ed;
  --green:  #1a6b4a;
  --green2: #e4f4ec;
  --red:    #b93535;
  --red2:   #fdeaea;
  --purple: #5b3591;
  --purple2:#f0eafb;
  --teal:   #0e6b6b;
  --teal2:  #e0f4f4;
  --white:  #ffffff;
  --text:   #1a2130;
  --muted:  #5a6478;
  --border: #e2d9cc;
  --shadow: 0 2px 12px rgba(26,46,74,0.10);
  --shadow-lg: 0 8px 32px rgba(26,46,74,0.15);
  --r: 14px;
  --r-sm: 8px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--cream);
  color: var(--text);
  font-size: 16px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ── TYPOGRAPHY ── */
h1,h2,h3,h4 { font-family: 'Fraunces', serif; font-weight: 700; line-height: 1.2; }
.serif { font-family: 'Fraunces', serif; }

/* ── UTILITY ── */
.container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
.tag { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 700;
       letter-spacing: 0.08em; padding: 4px 10px; border-radius: 20px; text-transform: uppercase; }
.emoji-icon { font-size: 28px; line-height: 1; }
.hidden { display: none !important; }

/* ── NAVIGATION ── */
nav {
  background: var(--navy);
  position: sticky; top: 0; z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.25);
}
.nav-inner {
  display: flex; align-items: center; gap: 16px;
  padding: 0 20px; height: 60px; max-width: 1100px; margin: 0 auto;
}
.nav-logo {
  font-family: 'Fraunces', serif; font-weight: 900; font-size: 18px;
  color: white; text-decoration: none; white-space: nowrap;
  display: flex; align-items: center; gap: 8px;
}
.nav-logo span { color: #f4c661; }
.nav-tabs { display: flex; gap: 4px; flex: 1; overflow-x: auto; scrollbar-width: none; }
.nav-tabs::-webkit-scrollbar { display: none; }
.nav-tab {
  background: none; border: none; color: rgba(255,255,255,0.65);
  padding: 8px 14px; border-radius: 8px; cursor: pointer;
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; font-weight: 600;
  white-space: nowrap; transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
}
.nav-tab:hover { color: white; background: rgba(255,255,255,0.1); }
.nav-tab.active { color: white; background: rgba(255,255,255,0.18); }
.nav-search {
  background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
  color: white; padding: 7px 14px; border-radius: 8px; font-size: 13px;
  font-family: 'Plus Jakarta Sans', sans-serif; width: 160px; outline: none;
  transition: all 0.2s;
}
.nav-search::placeholder { color: rgba(255,255,255,0.45); }
.nav-search:focus { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.4); width: 200px; }

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 60%, #2d5a8e 100%);
  padding: 64px 20px 80px;
  position: relative; overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 70% 50%, rgba(244,198,97,0.12) 0%, transparent 60%),
              radial-gradient(ellipse at 10% 80%, rgba(37,99,168,0.3) 0%, transparent 50%);
}
.hero-inner { max-width: 1100px; margin: 0 auto; position: relative; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(244,198,97,0.18); border: 1px solid rgba(244,198,97,0.3);
  color: #f4c661; padding: 6px 14px; border-radius: 20px;
  font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  margin-bottom: 20px;
}
.hero h1 {
  font-size: clamp(36px, 6vw, 60px); color: white;
  margin-bottom: 16px; max-width: 720px;
}
.hero h1 em { color: #f4c661; font-style: italic; }
.hero p {
  font-size: 18px; color: rgba(255,255,255,0.75);
  max-width: 580px; margin-bottom: 36px; line-height: 1.7;
}
.hero-stats {
  display: flex; gap: 32px; flex-wrap: wrap;
}
.hero-stat { text-align: left; }
.hero-stat-num {
  font-family: 'Fraunces', serif; font-size: 36px; font-weight: 900;
  color: #f4c661; line-height: 1;
}
.hero-stat-label { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 4px; }
.hero-deco {
  position: absolute; right: -20px; top: 50%; transform: translateY(-50%);
  font-size: 180px; opacity: 0.06; pointer-events: none;
  font-family: 'Fraunces', serif;
}

/* ── SUBJECT TABS (main panel) ── */
.subject-nav {
  background: var(--white); border-bottom: 2px solid var(--border);
  position: sticky; top: 60px; z-index: 90;
}
.subject-nav-inner {
  display: flex; gap: 0; max-width: 1100px; margin: 0 auto; padding: 0 20px;
  overflow-x: auto; scrollbar-width: none;
}
.subject-nav-inner::-webkit-scrollbar { display: none; }
.subj-btn {
  background: none; border: none; border-bottom: 3px solid transparent;
  padding: 16px 20px; font-size: 15px; font-weight: 600; cursor: pointer;
  font-family: 'Plus Jakarta Sans', sans-serif; white-space: nowrap;
  color: var(--muted); transition: all 0.2s; display: flex; align-items: center; gap: 8px;
}
.subj-btn:hover { color: var(--navy); }
.subj-btn.active-math { color: var(--blue); border-bottom-color: var(--blue); }
.subj-btn.active-science { color: var(--teal); border-bottom-color: var(--teal); }

/* ── MAIN CONTENT ── */
.main { padding: 40px 20px 80px; }

/* ── SECTION HEADER ── */
.section-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 16px; margin-bottom: 32px; flex-wrap: wrap;
}
.section-title { font-size: clamp(24px, 4vw, 32px); color: var(--navy); }
.section-subtitle { font-size: 15px; color: var(--muted); margin-top: 6px; }
.teks-count-badge {
  background: var(--navy); color: white; padding: 6px 14px;
  border-radius: 20px; font-size: 13px; font-weight: 700; white-space: nowrap;
  flex-shrink: 0; align-self: flex-start; margin-top: 4px;
}

/* ── DOMAIN GROUP ── */
.domain-group { margin-bottom: 48px; }
.domain-header {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 20px; padding-bottom: 12px;
  border-bottom: 2px solid var(--border);
}
.domain-icon { font-size: 24px; }
.domain-name { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 700; }
.domain-count { font-size: 13px; color: var(--muted); margin-left: auto; }

/* ── TEKS CARDS GRID ── */
.teks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
}

/* ── TEKS CARD ── */
.teks-card {
  background: var(--white); border-radius: var(--r);
  border: 1.5px solid var(--border); overflow: hidden;
  transition: box-shadow 0.25s, transform 0.2s, border-color 0.2s;
  cursor: pointer;
}
.teks-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); border-color: transparent; }
.teks-card-top {
  padding: 18px 20px 14px;
  display: flex; align-items: flex-start; gap: 14px;
}
.teks-badge {
  font-family: 'Fraunces', serif; font-weight: 700; font-size: 13px;
  padding: 6px 12px; border-radius: 8px; white-space: nowrap; flex-shrink: 0;
  line-height: 1.2;
}
.teks-card-info { flex: 1; min-width: 0; }
.teks-card-name { font-weight: 700; font-size: 15px; color: var(--navy); margin-bottom: 4px; }
.teks-card-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
.teks-card-footer {
  border-top: 1px solid var(--border); padding: 10px 20px;
  display: flex; align-items: center; justify-content: space-between;
  background: var(--cream);
}
.teks-card-footer-label { font-size: 12px; color: var(--muted); font-weight: 500; }
.teks-card-arrow { font-size: 16px; color: var(--muted); transition: transform 0.2s; }
.teks-card:hover .teks-card-arrow { transform: translateX(4px); }

/* ── MODAL (TEKS DETAIL) ── */
.modal-overlay {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(10,18,34,0.6); backdrop-filter: blur(4px);
  display: flex; align-items: flex-end;
  opacity: 0; transition: opacity 0.3s;
  pointer-events: none;
}
@media (min-width: 640px) {
  .modal-overlay { align-items: center; justify-content: center; }
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal {
  background: var(--white); width: 100%; max-width: 680px;
  max-height: 92vh; overflow-y: auto;
  border-radius: var(--r) var(--r) 0 0;
  transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.32,0.72,0,1);
  position: relative;
}
@media (min-width: 640px) {
  .modal { border-radius: var(--r); transform: translateY(20px) scale(0.97); }
  .modal-overlay.open .modal { transform: translateY(0) scale(1); }
}
.modal-overlay.open .modal { transform: translateY(0); }
.modal-drag-handle {
  width: 40px; height: 4px; background: var(--border); border-radius: 4px;
  margin: 12px auto 0;
}
@media (min-width: 640px) { .modal-drag-handle { display: none; } }
.modal-header {
  padding: 20px 24px 0;
}
.modal-teks-code {
  font-family: 'Fraunces', serif; font-size: 13px; font-weight: 700;
  padding: 5px 12px; border-radius: 6px; display: inline-block; margin-bottom: 10px;
}
.modal-title { font-size: clamp(20px, 4vw, 26px); color: var(--navy); margin-bottom: 6px; }
.modal-subject-tag { font-size: 12px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
.modal-close {
  position: absolute; top: 16px; right: 16px;
  background: var(--cream2); border: none; border-radius: 50%;
  width: 36px; height: 36px; font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: var(--muted); transition: all 0.2s;
}
.modal-close:hover { background: var(--border); color: var(--text); }
.modal-body { padding: 24px; }

/* ── MODAL SECTIONS ── */
.modal-section { margin-bottom: 20px; border-radius: var(--r-sm); overflow: hidden; }
.modal-section-label {
  padding: 8px 16px; font-size: 11px; font-weight: 800;
  letter-spacing: 0.1em; text-transform: uppercase;
  display: flex; align-items: center; gap: 8px;
}
.modal-section-body { padding: 14px 16px; font-size: 15px; line-height: 1.75; }
.modal-section-body p { margin-bottom: 10px; }
.modal-section-body p:last-child { margin-bottom: 0; }

.sec-what .modal-section-label { background: #dbeafe; color: #1e40af; }
.sec-what .modal-section-body { background: #f0f7ff; }
.sec-example .modal-section-label { background: #fef3c7; color: #92400e; }
.sec-example .modal-section-body { background: #fffbf0; }
.sec-why .modal-section-label { background: #e4f4ec; color: #1a5c3a; }
.sec-why .modal-section-body { background: #f0fbf5; }

.tip-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.tip-item {
  display: flex; gap: 12px; align-items: flex-start;
  background: var(--cream); border-radius: var(--r-sm);
  padding: 12px 14px;
}
.tip-check { color: var(--green); font-size: 16px; flex-shrink: 0; margin-top: 1px; font-weight: 700; }
.tip-text { font-size: 14px; line-height: 1.6; }

.try-this-box {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  border: 2px solid #f4c661; border-radius: var(--r-sm);
  padding: 18px 20px;
}
.try-this-label {
  font-family: 'Fraunces', serif; font-size: 14px; font-weight: 700;
  color: var(--amber); margin-bottom: 10px;
  display: flex; align-items: center; gap: 8px;
}
.try-this-text { font-size: 14px; line-height: 1.75; }

.modal-section-h { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }

/* ── MISSED RATE BAR ── */
.missed-bar-wrap { margin-bottom: 24px; }
.missed-bar-label { display: flex; justify-content: space-between; font-size: 13px; color: var(--muted); margin-bottom: 6px; }
.missed-bar-track { height: 10px; background: var(--cream2); border-radius: 5px; overflow: hidden; }
.missed-bar-fill { height: 100%; border-radius: 5px; transition: width 1s ease; }

/* ── SEARCH RESULTS ── */
.search-results-header { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
.search-results-header strong { color: var(--navy); }

/* ── RESOURCES SECTION ── */
.resources-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
.resource-card {
  background: var(--white); border: 1.5px solid var(--border); border-radius: var(--r);
  padding: 20px; transition: all 0.2s; text-decoration: none; color: inherit;
  display: flex; flex-direction: column; gap: 8px;
}
.resource-card:hover { box-shadow: var(--shadow); border-color: var(--navy); transform: translateY(-2px); }
.resource-icon { font-size: 28px; }
.resource-name { font-weight: 700; font-size: 15px; color: var(--navy); }
.resource-url { font-size: 12px; color: var(--blue); font-weight: 600; }
.resource-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
.resource-tag { font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 20px; align-self: flex-start; }

/* ── TIPS OVERVIEW PAGE ── */
.tips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
.tip-card {
  background: var(--white); border: 1.5px solid var(--border); border-radius: var(--r);
  padding: 24px; transition: all 0.2s;
}
.tip-card:hover { box-shadow: var(--shadow); }
.tip-card-icon { font-size: 36px; margin-bottom: 12px; }
.tip-card-title { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.tip-card-body { font-size: 14px; color: var(--muted); line-height: 1.7; }

/* ── FOOTER ── */
footer {
  background: var(--navy); color: rgba(255,255,255,0.7);
  padding: 40px 20px; text-align: center; font-size: 14px;
}
footer strong { color: white; }

/* ── FADE IN ANIMATION ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.teks-card { animation: fadeUp 0.4s ease both; }
.teks-card:nth-child(1) { animation-delay: 0.05s; }
.teks-card:nth-child(2) { animation-delay: 0.10s; }
.teks-card:nth-child(3) { animation-delay: 0.15s; }
.teks-card:nth-child(4) { animation-delay: 0.20s; }
.teks-card:nth-child(5) { animation-delay: 0.25s; }
.teks-card:nth-child(6) { animation-delay: 0.30s; }

/* ── MOBILE OPTIMIZATIONS ── */
@media (max-width: 640px) {
  .hero { padding: 40px 20px 60px; }
  .hero-deco { display: none; }
  .hero-stats { gap: 20px; }
  .nav-search { display: none; }
  .teks-grid { grid-template-columns: 1fr; }
  .modal-body { padding: 16px; }
  .modal-title { font-size: 20px; }
  .section-header { flex-direction: column; gap: 8px; }
  .teks-count-badge { align-self: flex-start; }
}
@media (max-width: 400px) {
  .nav-logo { font-size: 15px; }
  .nav-tab { font-size: 12px; padding: 7px 10px; }
}

/* ── LOADING STATE ── */
.loading-dots {
  display: flex; gap: 6px; justify-content: center; padding: 60px;
}
.loading-dots span {
  width: 10px; height: 10px; background: var(--navy); border-radius: 50%;
  animation: bounce 1s ease infinite;
}
.loading-dots span:nth-child(2) { animation-delay: 0.15s; }
.loading-dots span:nth-child(3) { animation-delay: 0.30s; }
@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }

/* ── SUBJECT COLOR THEMES ── */
/* Math */
.math-badge  { background: #dbeafe; color: #1e40af; }
.math-accent { color: var(--blue); }
.math-bg     { background: var(--blue); }
/* Science - Investigation */
.sci-inv-badge  { background: #e0f4f4; color: var(--teal); }
.sci-inv-accent { color: var(--teal); }
/* Science - Energy */
.sci-nrg-badge  { background: #fef0d8; color: var(--amber); }
.sci-nrg-accent { color: var(--amber); }
/* Science - Ecosystems */
.sci-eco-badge  { background: var(--green2); color: var(--green); }
.sci-eco-accent { color: var(--green); }
/* Science - Earth */
.sci-earth-badge  { background: var(--purple2); color: var(--purple); }
.sci-earth-accent { color: var(--purple); }

.nav-math-dot   { width: 8px; height: 8px; border-radius: 50%; background: var(--blue); }
.nav-sci-dot    { width: 8px; height: 8px; border-radius: 50%; background: var(--teal); }

/* ── MISSED INDICATOR COLORS ── */
.miss-high   { background: var(--red);    color: white; }
.miss-medium { background: var(--amber);  color: white; }
.miss-low    { background: var(--green);  color: white; }
.miss-high-bar   { background: var(--red); }
.miss-medium-bar { background: var(--amber); }
.miss-low-bar    { background: var(--green); }

/* ── BACK TO TOP ── */
#back-top {
  position: fixed; bottom: 20px; right: 20px; z-index: 150;
  background: var(--navy); color: white; border: none; border-radius: 50%;
  width: 44px; height: 44px; font-size: 18px; cursor: pointer;
  box-shadow: var(--shadow-lg); transition: all 0.2s; opacity: 0; transform: scale(0.8);
}
#back-top.visible { opacity: 1; transform: scale(1); }
#back-top:hover { background: var(--blue); transform: scale(1.1); }

/* ── HIGHLIGHT on search ── */
.hl { background: #fef9c3; border-radius: 3px; padding: 0 2px; }

/* ── TABS PANEL CONTENT ── */
.panel { display: none; }
.panel.active { display: block; }

/* ── QUESTION GENERATOR ── */
.qgen-section {
  margin-top: 32px; border-top: 2px solid var(--border); padding-top: 28px;
}
.qgen-header {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; margin-bottom: 20px; flex-wrap: wrap;
}
.qgen-title {
  font-family: 'Fraunces', serif; font-size: 18px; font-weight: 700;
  color: var(--navy); display: flex; align-items: center; gap: 8px;
}
.qgen-controls { display: flex; gap: 8px; flex-wrap: wrap; }
.qgen-btn {
  border: none; padding: 9px 18px; border-radius: 8px; font-size: 13px; font-weight: 700;
  cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif; transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
}
.qgen-btn-primary { background: var(--navy); color: white; }
.qgen-btn-primary:hover { background: var(--blue); transform: translateY(-1px); }
.qgen-btn-secondary { background: var(--cream2); color: var(--navy); border: 1px solid var(--border); }
.qgen-btn-secondary:hover { background: var(--border); }

.question-card {
  background: var(--white); border: 1.5px solid var(--border); border-radius: var(--r-sm);
  margin-bottom: 16px; overflow: hidden; transition: box-shadow 0.2s;
}
.question-card:hover { box-shadow: var(--shadow); }
.question-top {
  padding: 16px 18px;
}
.question-num {
  display: inline-flex; align-items: center; justify-content: center;
  width: 26px; height: 26px; background: var(--navy); color: white;
  border-radius: 50%; font-size: 12px; font-weight: 700; flex-shrink: 0;
  margin-right: 10px; vertical-align: middle;
}
.question-type-badge {
  font-size: 10px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase;
  padding: 2px 8px; border-radius: 10px; margin-left: 8px; vertical-align: middle;
}
.qtype-mc  { background: #dbeafe; color: #1e40af; }
.qtype-oe  { background: #e4f4ec; color: #1a6b4a; }
.qtype-tf  { background: #fef0d8; color: #d4820a; }
.qtype-fr  { background: #f0eafb; color: #5b3591; }

.question-text {
