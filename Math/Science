/* ═══════════════════════════════════════════════════════
   PANEL SWITCHING
═══════════════════════════════════════════════════════ */
function switchPanel(name, navEl) {
  // Hide search
  document.getElementById('searchPanel').classList.remove('active');
  document.getElementById('globalSearch').value = '';

  // Show correct panel
  ['math','science','tips','resources'].forEach(p => {
    document.getElementById(p+'Panel').classList.toggle('active', p === name);
  });

  // Update nav-tabs
  document.querySelectorAll('.nav-tab').forEach(b => {
    b.classList.toggle('active', b.dataset.panel === name);
  });

  // Update subject-nav buttons
  ['math','science','tips','resources'].forEach(p => {
    const btn = document.getElementById(p+'Btn');
    if (btn) {
      btn.className = 'subj-btn';
      if (p === name) {
        btn.classList.add(p === 'math' ? 'active-math' : p === 'science' ? 'active-science' : 'active-math');
      }
    }
  });

  window.scrollTo({top: document.getElementById('subjectNav').offsetTop - 60, behavior:'smooth'});
}

/* ═══════════════════════════════════════════════════════
   RENDER TEKS CARDS
═══════════════════════════════════════════════════════ */
function missedColor(pct) {
  if (pct >= 50) return {bar:'miss-high-bar', badge:'miss-high', label:'High priority'};
  if (pct >= 30) return {bar:'miss-medium-bar', badge:'miss-medium', label:'Medium priority'};
  return {bar:'miss-low-bar', badge:'miss-low', label:'Lower priority'};
}

function createCard(teks, index) {
  const mc = missedColor(teks.missedPct);
  const card = document.createElement('div');
  card.className = 'teks-card';
  card.style.animationDelay = (index * 0.05) + 's';
  card.setAttribute('data-teks', teks.code);
  card.setAttribute('data-name', teks.name.toLowerCase());
  card.setAttribute('data-desc', teks.desc.toLowerCase());
  card.onclick = () => openModal(teks);
  card.innerHTML = `
    <div class="teks-card-top">
      <div class="teks-badge ${teks.badge}">${teks.code}</div>
      <div class="teks-card-info">
        <div class="teks-card-name">${teks.name}</div>
        <div class="teks-card-desc">${teks.desc}</div>
      </div>
    </div>
    <div class="teks-card-footer">
      <div>
        <div class="teks-card-footer-label">Class missed rate</div>
        <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
          <div style="width:80px;height:6px;background:#e2d9cc;border-radius:3px;overflow:hidden">
            <div class="${mc.bar}" style="height:100%;width:${teks.missedPct}%;border-radius:3px;transition:width 1s"></div>
          </div>
          <span class="tag ${mc.badge}" style="padding:2px 8px;font-size:10px">${teks.missedPct}% missed</span>
        </div>
      </div>
      <div class="teks-card-arrow">→</div>
    </div>`;
  return card;
}

function renderCards(gridId, teksArr, domainFilter) {
  const grid = document.getElementById(gridId);
  if (!grid) return;
  grid.innerHTML = '';
  const filtered = teksArr.filter(t => t.domain === domainFilter);
  filtered.forEach((t, i) => grid.appendChild(createCard(t, i)));
}

// Render all grids
renderCards('mathGrid1', MATH_TEKS, 1);
renderCards('mathGrid2', MATH_TEKS, 2);
renderCards('mathGrid3', MATH_TEKS, 3);
renderCards('sciGrid1', SCI_TEKS, 1);
renderCards('sciGrid2', SCI_TEKS, 2);
renderCards('sciGrid3', SCI_TEKS, 3);
renderCards('sciGrid4', SCI_TEKS, 4);

/* ═══════════════════════════════════════════════════════
   MODAL — LEARN TAB + PRACTICE TAB
═══════════════════════════════════════════════════════ */
let currentTeks = null;

function switchModalTab(tab, btn) {
  document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.modal-tab-content').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('modal' + (tab === 'learn' ? 'Learn' : 'Practice') + 'Tab').classList.add('active');
  if (tab === 'practice' && currentTeks) renderPractice(currentTeks);
}

function openModal(teks) {
  currentTeks = teks;
  const mc = missedColor(teks.missedPct);
  const badgeColors = {
    'math-badge':      {bg:'#dbeafe',color:'#1e40af'},
    'sci-inv-badge':   {bg:'#e0f4f4',color:'#0e6b6b'},
    'sci-nrg-badge':   {bg:'#fdf0d8',color:'#d4820a'},
    'sci-eco-badge':   {bg:'#e4f4ec',color:'#1a6b4a'},
    'sci-earth-badge': {bg:'#f0eafb',color:'#5b3591'},
  };
  const bc = badgeColors[teks.badge] || {bg:'#e2e8f0',color:'#1a2e4a'};

  document.getElementById('modalCode').textContent = teks.code;
  document.getElementById('modalCode').style.background = bc.bg;
  document.getElementById('modalCode').style.color = bc.color;
  document.getElementById('modalTitle').textContent = teks.name;
  document.getElementById('modalSubject').textContent = teks.subject;

  // Reset tabs to Learn
  document.querySelectorAll('.modal-tab').forEach((t,i) => t.classList.toggle('active', i===0));
  document.getElementById('modalLearnTab').classList.add('active');
  document.getElementById('modalPracticeTab').classList.remove('active');

  const tipsHtml = teks.tips.map(t => `
    <li class="tip-item">
      <span class="tip-check">✓</span>
      <span class="tip-text">${t}</span>
    </li>`).join('');

  document.getElementById('modalLearnBody').innerHTML = `
    <div class="missed-bar-wrap">
      <div class="missed-bar-label">
        <span>Class missed rate for this standard</span>
        <span style="font-weight:700">${teks.missedPct}%</span>
      </div>
      <div class="missed-bar-track">
        <div class="missed-bar-fill ${mc.bar}" style="width:0%"></div>
      </div>
    </div>
    <div class="modal-section sec-what">
      <div class="modal-section-label">📘 What is this standard?</div>
      <div class="modal-section-body">${teks.what}</div>
    </div>
    <div class="modal-section sec-example">
      <div class="modal-section-label">🌍 Real-world example</div>
      <div class="modal-section-body">${teks.example}</div>
    </div>
    <div class="modal-section sec-why">
      <div class="modal-section-label">💡 Why it matters</div>
      <div class="modal-section-body">${teks.why}</div>
    </div>
    <div style="margin-bottom:20px">
      <div class="modal-section-h">🏠 How you can help at home</div>
      <ul class="tip-list">${tipsHtml}</ul>
    </div>
    <div class="try-this-box">
      <div class="try-this-label">⭐ Try This Tonight</div>
      <div class="try-this-text">${teks.tryThis}</div>
    </div>
  `;

  // Clear practice tab
  document.getElementById('modalPracticeBody').innerHTML = '';

  const overlay = document.getElementById('modalOverlay');
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';

  setTimeout(() => {
    const fill = document.querySelector('#modalLearnBody .missed-bar-fill');
    if (fill) fill.style.width = teks.missedPct + '%';
  }, 150);
}

/* ── RESOLVE QUESTION KEY ── */
function getQuestions(teks) {
  // Try direct code match, then try with _math or _sci suffix
  return QUESTIONS[teks.code] ||
         QUESTIONS[teks.code + '_math'] ||
         QUESTIONS[teks.code + '_sci'] ||
         null;
}

/* ── RENDER PRACTICE TAB ── */
function renderPractice(teks) {
  const body = document.getElementById('modalPracticeBody');
  if (body.dataset.rendered === teks.code) return; // already rendered
  body.dataset.rendered = teks.code;

  const qs = getQuestions(teks);
  if (!qs) {
    body.innerHTML = `<div style="text-align:center;padding:40px;color:var(--muted)">
      <div style="font-size:36px;margin-bottom:12px">🔧</div>
      <p>Practice questions for <strong>${teks.code}</strong> coming soon!</p>
    </div>`;
    return;
  }

  body.innerHTML = `
    <div style="background:var(--cream2);border-radius:var(--r-sm);padding:14px 16px;margin-bottom:20px;font-size:14px;color:var(--muted)">
      <strong style="color:var(--navy)">✏️ ${qs.length} Practice Questions</strong> — Click an answer choice to check it, or tap <em>"Show Answer Key"</em> to see the full step-by-step solution.
    </div>
    ${qs.map((q, i) => renderQuestion(q, i, teks.code)).join('')}
  `;
}

function renderQuestion(q, i, teksCode) {
  const qid = `q_${teksCode}_${i}`.replace(/[^a-z0-9_]/gi,'_');
  const typeBadge = q.type === 'mc' ? '<span class="question-type-badge qtype-mc">Multiple Choice</span>' :
                    q.type === 'oe' ? '<span class="question-type-badge qtype-oe">Open Ended</span>' :
                    '<span class="question-type-badge qtype-fr">Short Answer</span>';

  const optionsHtml = q.type === 'mc' ? `
    <div class="mc-options" id="opts_${qid}">
      ${q.options.map((opt, j) => `
        <button class="mc-option" onclick="checkAnswer('${qid}',${j},${q.answer})">
          <span class="mc-letter">${opt.l}</span>
          <span>${opt.t}</span>
        </button>`).join('')}
    </div>` :
    `<div style="background:var(--cream);border-radius:var(--r-sm);padding:12px 16px;margin-top:10px;font-size:13px;color:var(--muted);font-style:italic">
      Write your answer on paper, then tap "Show Answer Key" below to compare ↓
    </div>`;

  const stepsHtml = q.steps.map((s, si) => `
    <div class="answer-step">
      <div class="step-num">${si+1}</div>
      <div class="step-text">${s}</div>
    </div>`).join('');

  return `
    <div class="question-card">
      <div class="question-top">
        <div>
          <span class="question-num">${i+1}</span>${typeBadge}
        </div>
        <div class="question-text">${q.text}</div>
        ${optionsHtml}
      </div>
      <button class="answer-key-toggle" id="toggle_${qid}" onclick="toggleAnswer('${qid}')">
        <span>🔑 Show Answer Key & Step-by-Step Explanation</span>
        <span class="chevron">▼</span>
      </button>
      <div class="answer-key-body" id="body_${qid}">
        <div class="answer-correct-label">✅ Answer & Explanation</div>
        <div class="answer-steps">${stepsHtml}</div>
        <div class="answer-final">${q.final}</div>
      </div>
    </div>`;
}

function checkAnswer(qid, chosen, correct) {
  const opts = document.querySelectorAll(`#opts_${qid} .mc-option`);
  opts.forEach((btn, i) => {
    btn.onclick = null; // disable after first click
    if (i === correct) btn.classList.add('reveal');
    else if (i === chosen) btn.classList.add('wrong');
  });
  // Auto-show answer key
  const body = document.getElementById('body_' + qid);
  const toggle = document.getElementById('toggle_' + qid);
  if (body && !body.classList.contains('open')) {
    body.classList.add('open');
    toggle.classList.add('revealed');
    toggle.querySelector('span:first-child').textContent = '🔑 Answer Key (click to close)';
  }
}

function toggleAnswer(qid) {
  const body = document.getElementById('body_' + qid);
  const toggle = document.getElementById('toggle_' + qid);
  const isOpen = body.classList.toggle('open');
  toggle.classList.toggle('revealed', isOpen);
  toggle.querySelector('span:first-child').textContent = isOpen
    ? '🔑 Answer Key (click to close)'
    : '🔑 Show Answer Key & Step-by-Step Explanation';
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
  currentTeks = null;
  // Reset practice tab render flag
  const pb = document.getElementById('modalPracticeBody');
  if (pb) pb.dataset.rendered = '';
}

function closeModalOnOverlay(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

/* ═══════════════════════════════════════════════════════
   GLOBAL SEARCH
═══════════════════════════════════════════════════════ */
function handleSearch(query) {
  const q = query.trim().toLowerCase();
  if (!q) {
    document.getElementById('searchPanel').classList.remove('active');
    document.getElementById('mathPanel').classList.add('active');
    document.querySelectorAll('.nav-tab').forEach(b => b.classList.toggle('active', b.dataset.panel === 'math'));
    return;
  }

  // Hide all panels, show search
  ['math','science','tips','resources'].forEach(p => {
    document.getElementById(p+'Panel').classList.remove('active');
  });
  document.querySelectorAll('.nav-tab').forEach(b => b.classList.remove('active'));
  document.getElementById('searchPanel').classList.add('active');

  const ALL_TEKS = [...MATH_TEKS, ...SCI_TEKS];
  const results = ALL_TEKS.filter(t =>
    t.code.toLowerCase().includes(q) ||
    t.name.toLowerCase().includes(q) ||
    t.desc.toLowerCase().includes(q) ||
    t.what.toLowerCase().includes(q) ||
    t.subject.toLowerCase().includes(q)
  );

  document.getElementById('searchStatus').innerHTML =
    `Found <strong>${results.length}</strong> standard${results.length!==1?'s':''} matching "<strong>${query}</strong>"`;

  const grid = document.getElementById('searchGrid');
  grid.innerHTML = '';
  results.forEach((t, i) => grid.appendChild(createCard(t, i)));

  if (results.length === 0) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--muted)">
      <div style="font-size:48px;margin-bottom:16px">🔍</div>
      <p style="font-size:16px">No standards found for "<strong>${query}</strong>"</p>
      <p style="font-size:14px;margin-top:8px">Try searching by code (e.g., "5.6.B"), topic (e.g., "fractions"), or keyword</p>
    </div>`;
  }
}

