}
.mc-option:hover { border-color: var(--navy); background: #eef3ff; }
.mc-option.correct { border-color: var(--green); background: var(--green2); }
.mc-option.wrong   { border-color: var(--red); background: var(--red2); }
.mc-option.reveal  { border-color: var(--green); background: var(--green2); }
.mc-letter {
  font-weight: 700; color: var(--navy); min-width: 20px; font-size: 14px; flex-shrink: 0;
}

.answer-key-toggle {
  width: 100%; padding: 12px 18px; background: var(--cream2);
  border: none; border-top: 1.5px solid var(--border); cursor: pointer;
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; font-weight: 600;
  color: var(--muted); display: flex; align-items: center; justify-content: space-between;
  transition: all 0.2s; text-align: left;
}
.answer-key-toggle:hover { background: var(--border); color: var(--navy); }
.answer-key-toggle.revealed { background: #e6f4ec; color: var(--green); border-top-color: #b6e0c8; }
.answer-key-toggle .chevron { transition: transform 0.3s; font-size: 16px; }
.answer-key-toggle.revealed .chevron { transform: rotate(180deg); }

.answer-key-body {
  display: none; padding: 16px 18px;
  background: linear-gradient(135deg, #f0fbf5, #e6f4ec);
  border-top: 1px solid #b6e0c8;
}
.answer-key-body.open { display: block; }
.answer-correct-label {
  font-weight: 700; color: var(--green); font-size: 13px;
  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px;
  display: flex; align-items: center; gap: 6px;
}
.answer-steps { display: flex; flex-direction: column; gap: 10px; }
.answer-step {
  display: flex; gap: 12px; align-items: flex-start;
}
.step-num {
  min-width: 24px; height: 24px; background: var(--green); color: white;
  border-radius: 50%; font-size: 11px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;
}
.step-text { font-size: 14px; line-height: 1.65; color: var(--text); }
.step-text strong { color: var(--navy); }
.answer-final {
  margin-top: 12px; padding: 10px 14px;
  background: white; border-radius: var(--r-sm); border-left: 4px solid var(--green);
  font-size: 14px; font-weight: 600; color: var(--green);
}

/* Loading spinner for questions */
